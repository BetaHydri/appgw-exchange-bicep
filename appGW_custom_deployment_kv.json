    {
      "condition": "[and(parameters('deployAppGateway'), not(empty(parameters('sslCertData'))))]",
      "type": "Microsoft.Resources/deploymentScripts",
      "apiVersion": "2023-08-01",
      "name": "import-pfx-to-keyvault",
      "location": "[parameters('location')]",
      "kind": "AzureCLI",
      "identity": {
        "type": "UserAssigned",
        "userAssignedIdentities": {
          "[format('{0}', resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('managedIdentityName')))]": {}
        }
      },
      "properties": {
        "azCliVersion": "2.67.0",
        "retentionInterval": "PT1H",
        "timeout": "PT10M",
        "environmentVariables": [
          {
            "name": "KV_NAME",
            "value": "[parameters('keyVaultName')]"
          },
          {
            "name": "CERT_NAME",
            "value": "[parameters('keyVaultCertificateName')]"
          },
          {
            "name": "PFX_BASE64",
            "secureValue": "[parameters('sslCertData')]"
          },
          {
            "name": "PFX_PASSWORD",
            "secureValue": "[parameters('sslCertPassword')]"
          },
          {
            "name": "NOTIFY_EMAILS",
            "value": "[join(parameters('certExpiryNotificationEmails'), ',')]"
          }
        ],
        "scriptContent": "      set -e\n      echo \"$PFX_BASE64\" | base64 -d > /tmp/cert.pfx\n      if [ -n \"$PFX_PASSWORD\" ]; then\n        az keyvault certificate import \\\n          --vault-name \"$KV_NAME\" \\\n          --name \"$CERT_NAME\" \\\n          --file /tmp/cert.pfx \\\n          --password \"$PFX_PASSWORD\"\n      else\n        az keyvault certificate import \\\n          --vault-name \"$KV_NAME\" \\\n          --name \"$CERT_NAME\" \\\n          --file /tmp/cert.pfx\n      fi\n      rm -f /tmp/cert.pfx\n\n      # Configure lifetime action: email notification 30 days before expiry\n      az keyvault certificate set-attributes \\\n        --vault-name \"$KV_NAME\" \\\n        --name \"$CERT_NAME\" \\\n        --policy \"$(az keyvault certificate show \\\n          --vault-name \"$KV_NAME\" \\\n          --name \"$CERT_NAME\" \\\n          --query policy -o json | \\\n          jq '.lifetime_actions = [{\"action\":{\"action_type\":\"EmailContacts\"},\"trigger\":{\"days_before_expiry\":30}}]')\"\n\n      # Add notification contacts (skip if already exists to ensure idempotent redeployments)\n      if [ -n \"$NOTIFY_EMAILS\" ]; then\n        EXISTING=$(az keyvault certificate contact list --vault-name \"$KV_NAME\" --query \"[].emailAddress\" -o tsv 2>/dev/null || true)\n        IFS=',' read -ra EMAILS <<< \"$NOTIFY_EMAILS\"\n        for EMAIL in \"${EMAILS[@]}\"; do\n          if echo \"$EXISTING\" | grep -qiF \"$EMAIL\"; then\n            echo \"Contact $EMAIL already exists, skipping.\"\n          else\n            az keyvault certificate contact add \\\n              --vault-name \"$KV_NAME\" \\\n              --email \"$EMAIL\"\n          fi\n        done\n      fi\n\n      SECRET_URI=$(az keyvault certificate show \\\n        --vault-name \"$KV_NAME\" \\\n        --name \"$CERT_NAME\" \\\n        --query sid -o tsv)\n      echo \"{\\\"secretUri\\\": \\\"$SECRET_URI\\\"}\" > $AZ_SCRIPTS_OUTPUT_PATH\n    "
      },
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName'))]",
        "[extensionResourceId(resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName')), 'Microsoft.Authorization/roleAssignments', guid(resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName')), resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('managedIdentityName')), 'a4417e6f-fecd-4de8-b567-7b0420556985'))]",
        "[extensionResourceId(resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName')), 'Microsoft.Authorization/roleAssignments', guid(resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName')), resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('managedIdentityName')), '4633458b-17de-408a-b874-0445c86b69e6'))]",
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('managedIdentityName'))]"
      ]
    },
